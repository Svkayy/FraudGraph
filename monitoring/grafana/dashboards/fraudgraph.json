{
  "title": "FraudGraph \u2014 Real-time Monitoring",
  "uid": "fraudgraph",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "5s",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "timezone": "browser",
  "tags": [
    "fraudgraph"
  ],
  "panels": [
    {
      "type": "stat",
      "title": "Transactions scored",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(decision_total)",
          "legendFormat": "Transactions scored",
          "refId": "A",
          "instant": false,
          "range": true
        }
      ],
      "id": 1
    },
    {
      "type": "stat",
      "title": "Inference p99",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 100,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "1000 * histogram_quantile(0.99, sum(rate(inference_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "Inference p99",
          "refId": "A",
          "instant": false,
          "range": true
        }
      ],
      "id": 2
    },
    {
      "type": "stat",
      "title": "Decline rate",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 15,
                "color": "orange"
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 * sum(decision_total{decision=\"DECLINE\"}) / sum(decision_total)",
          "legendFormat": "Decline rate",
          "refId": "A",
          "instant": false,
          "range": true
        }
      ],
      "id": 3
    },
    {
      "type": "stat",
      "title": "Feature drift",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "HEALTHY",
                  "color": "green"
                },
                "1": {
                  "text": "DRIFT",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 1,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "feature_drift_alert",
          "legendFormat": "Feature drift",
          "refId": "A",
          "instant": false,
          "range": true
        }
      ],
      "id": 4
    },
    {
      "type": "timeseries",
      "title": "Fraud score distribution (quantiles)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 24,
            "lineWidth": 2,
            "gradientMode": "opacity",
            "showPoints": "never",
            "lineInterpolation": "smooth"
          },
          "unit": ""
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.5, sum(rate(fraud_score_bucket[1m])) by (le))",
          "legendFormat": "p50",
          "refId": "A",
          "instant": false,
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.9, sum(rate(fraud_score_bucket[1m])) by (le))",
          "legendFormat": "p90",
          "refId": "B",
          "instant": false,
          "range": true
        }
      ],
      "id": 5
    },
    {
      "type": "piechart",
      "title": "Decision breakdown",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "APPROVE"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "FLAG"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "DECLINE"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (decision) (decision_total)",
          "legendFormat": "{{decision}}",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "id": 6
    },
    {
      "type": "timeseries",
      "title": "Inference latency (ms) \u2014 100ms SLO line",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 24,
            "lineWidth": 2,
            "gradientMode": "opacity",
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 100,
                "color": "red"
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "1000 * histogram_quantile(0.5, sum(rate(inference_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50",
          "refId": "A",
          "instant": false,
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "1000 * histogram_quantile(0.95, sum(rate(inference_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95",
          "refId": "B",
          "instant": false,
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "1000 * histogram_quantile(0.99, sum(rate(inference_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99",
          "refId": "C",
          "instant": false,
          "range": true
        }
      ],
      "id": 7
    },
    {
      "type": "timeseries",
      "title": "Transaction amount: rolling mean vs training mean",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 24,
            "lineWidth": 2,
            "gradientMode": "opacity",
            "showPoints": "never",
            "lineInterpolation": "smooth"
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "transaction_amount_mean",
          "legendFormat": "5-min rolling mean",
          "refId": "A",
          "instant": false,
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "train_amount_mean",
          "legendFormat": "training mean",
          "refId": "B",
          "instant": false,
          "range": true
        }
      ],
      "id": 8
    }
  ]
}